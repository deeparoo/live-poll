# Database
DATABASE_URL="postgresql://user:password@localhost:5432/livepoll"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV=development

# Super-admin: protects the all-sessions list at /admin/all
# Set to any long random string, e.g. openssl rand -hex 32
SUPER_ADMIN_TOKEN="change-me"

